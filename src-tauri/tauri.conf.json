{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "System Stats Monitoring",
  "version": "0.1.0",
  "identifier": "com.systemstats.monitoring",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "System Stats Monitoring",
        "width": 1120,
        "height": 720,
        "minWidth": 920,
        "minHeight": 620,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
